/*
  # Permissions-Policy: suppress deprecated FLoC/Topics headers that Turnstile triggers warnings for
  Permissions-Policy: browsing-topics=(), interest-cohort=()

  # Content-Security-Policy: allow Turnstile's challenge iframe, scripts, workers, and XHR
  # - script-src: challenges.cloudflare.com for Turnstile JS + 'unsafe-eval' required by Turnstile worker
  # - frame-src: challenges.cloudflare.com for the challenge iframe
  # - connect-src: challenges.cloudflare.com for the token verification XHR
  # - worker-src: blob: for Turnstile's internal Web Worker
  # - child-src: blob: required alongside worker-src in some browsers
  # NOTE: 'unsafe-inline' in script-src is intentionally absent; Turnstile uses
  #       explicit render and does not require it when loaded via api.js?render=explicit
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-eval' https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; frame-src https://challenges.cloudflare.com; connect-src 'self' https://challenges.cloudflare.com; worker-src blob:; child-src blob: https://challenges.cloudflare.com; object-src 'none'; base-uri 'self'; form-action 'self'
